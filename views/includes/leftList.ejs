<div class="leftList">
    <div class="insideList">
        <div class="topPart">
            <h3>Welcome <%= user.username %>
            </h3>
        </div>

        <div class="addFriend">
            <form id="addFriendForm" method="post" action="/friends/requests/send">
                <p id="labelFriendInp"></p>
                <input id="usernameInp" type="text" name="friendUsername" placeholder="Entrer username to add">
                <button type="submit">Send Invitation</button>
                <button id="requestsBTN" type="button">Requests</button>
            </form>
        </div>

        <div class="listFriendsDMs">
            <p></p>
        </div>

        <div id="settings" class="settings" data-id="<%= user.id %>">

        </div>
    </div>
</div>
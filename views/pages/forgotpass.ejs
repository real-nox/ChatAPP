<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <link rel="shortcut icon" href="../img/icon.png" type="image/x-icon">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="../css/guest.css">
</head>

<body>
    <%- include("../includes/topbar") %>

        <div class="center_container">
            <div class="container">
                <div class="topcontainer">
                    <h3>FORGOT PASSWORD</h3>
                </div>
                <div class="formcontainer">
                    <form method="post" action="get-user">
                        <div class="formElements">
                            <% if (locals.error !=undefined) {%>
                                <p id="error_p">
                                    <%= error %>
                                </p>
                                <% } %>
                                    <% if (locals.user==undefined) {%>
                                        <input type="text" name="email" class="email" placeholder="Email">
                                        <button type="submit">GET ACCOUNT</button>
                                        <% } else { %>
                                            <input type="text" name="email" class="email"
                                                value="<%=locals.user.email%>">
                                            <label for="pwd" id="CheckingPWD"></label>
                                            <div class="pwdC">
                                                <div class="pwdplace">
                                                    <input type="password" id="pwd" name="pwd" placeholder="Password"
                                                        maxlength="20">
                                                    <div class="outlinedc">
                                                        <span class="material-symbols-outlined outlined"
                                                            id="eye">visibility_off</span>
                                                    </div>
                                                </div>
                                                <div class="checkersPWD">
                                                    <p class="requirement up">• 1 uppercase letter</p>
                                                    <p class="requirement low">• 1 lowercase letter</p>
                                                    <p class="requirement n">• 1 number</p>
                                                    <p class="requirement sp">• 1 special character</p>
                                                </div>
                                            </div>

                                            <label for="passwordCheck" id="CheckingPassword"></label>
                                            <input type="password" id="passwordCheck" name="passwordCheck"
                                                maxlength="20" placeholder="Repeat your password">
                                            <button id="changePASS" type="submit" disabled>CHANGE PASSWORD</button>
                                            <% } %>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script src="../js/login.js"></script>

</body>

</html>